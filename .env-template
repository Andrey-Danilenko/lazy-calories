DEEPSEEK_API_KEY=
TELEGRAM_BOT_TOKEN=
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=
LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com

# Postgres. This localhost URL is for running the bot outside Docker; inside docker-compose
# the bot service overrides DATABASE_URL to use the "db" host.
DATABASE_URL=postgresql+asyncpg://lazy:lazy@localhost:5432/lazycalories

# Vector store (RAG nutrition cache). All optional — defaults shown.
# Embedded persistent Qdrant by default; set QDRANT_URL to use a Qdrant server instead.
QDRANT_PATH=stored_data/qdrant
QDRANT_URL=
QDRANT_COLLECTION=food_products
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
NUTRITION_SCORE_THRESHOLD=0.82
